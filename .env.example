# ============================================
# JULEX OS — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ============================================

# --- Supabase (Project Settings > API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
process.env.NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
process.env.SUPABASE_SECRET_KEY

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Stripe (card payments for credit top-ups) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_xxx
STRIPE_SECRET_KEY=sk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- M-Pesa Daraja API (Safaricom) ---
MPESA_ENV=sandbox              # sandbox | production
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_PASSKEY=your_lipa_na_mpesa_online_passkey
MPESA_SHORTCODE=your_till_or_paybill_shortcode
MPESA_CALLBACK_URL=https://your-domain.co.ke/api/payments/mpesa/callback

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAIL=patrick@dataprivacyadvocates.co.ke
